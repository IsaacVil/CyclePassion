      "response": []
    },
    {
      "name": "Workflow 2 – GET /partes?categorias=kawasaki,yamaha (sin tipo, hace scan)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('Cada parte coincide con alguna categoría', () => {",
              "  const cats = ['kawasaki','yamaha'];",
              "  j.parts.forEach(p => {",
              "    const hit = p.categories.some(c => cats.includes(c.toLowerCase()));",
              "    pm.expect(hit).to.be.true;",
              "  });",
              "});",
              "pm.test('Sin tipo: hace scan completo (no usa GSI)', () => {",
              "  pm.expect(j.parts).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Description",
            "value": "Sin tipo: realiza Scan en DynamoDB (no usa GSI). Con tipo usaría QueryCommand",
            "disabled": true
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/partes?categorias=electrico, motor",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "partes"
          ],
          "query": [
            {
              "key": "categorias",
              "value": "electrico, motor"
            }
          ]
        }
      },
      "response": []
    },
