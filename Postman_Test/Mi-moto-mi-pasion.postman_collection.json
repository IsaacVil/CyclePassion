    {
      "name": "Workflow 2 – GET /partes?tipo=motor",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('Solo tipo motor', () => {",
              "  j.parts.forEach(p => pm.expect(p.type.toLowerCase()).to.eql('motor'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/partes?tipo=motor",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "partes"
          ],
          "query": [
            {
              "key": "tipo",
              "value": "motor"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Workflow 2 – GET /partes?categorias=kawasaki,yamaha",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('Cada parte coincide con alguna categoría', () => {",
              "  const cats = ['honda','yamaha'];",
              "  j.parts.forEach(p => {",
              "    const hit = p.categories.some(c => cats.includes(c.toLowerCase()));",
              "    pm.expect(hit).to.be.true;",
              "  });",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/partes?categorias=kawasaki,yamaha",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "partes"
          ],
          "query": [
            {
              "key": "categorias",
              "value": "kawasaki,yamaha"
            }
          ]
        }
      },
      "response": []
    },
