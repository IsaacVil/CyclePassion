              "const j = pm.response.json();",
              "pm.test('Filtra tipo via GSI, luego categorías', () => {",
              "  j.parts.forEach(p => {",
              "    pm.expect(p.type.toLowerCase()).to.eql('suspension');",
              "    pm.expect(p.categories).to.include('ninja');",
              "  });",
