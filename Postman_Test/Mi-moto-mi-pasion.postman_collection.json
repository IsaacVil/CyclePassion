{
  "info": {
    "_postman_id": "11bc5e0d-0825-406b-9a16-2433b58cb72b",
    "name": "Mi moto mi pasión – API partes",
    "description": "Tests para el API serverless de partes de motocicletas con índice compuesto tipo-categoria",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "44697795"
  },
  "item": [
    {
      "name": "Workflow 1 – POST /partes (válido)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "const j = pm.response.json();",
              "pm.test('Tiene part con id', () => pm.expect(j.part).to.have.property('id'));",
              "pm.test('Campos correctos', () => {",
              "  pm.expect(j.part.name).to.eql('Amortiguador trasero');",
              "  pm.expect(j.part.type).to.eql('suspension');",
              "  pm.expect(j.part.price).to.eql(210);",
              "  pm.expect(j.part.categories).to.include('kawasaki');",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Amortiguador trasero Isaac Test\",\n  \"type\": \"suspension\",\n  \"price\": 210,\n  \"categories\": [\"kawasaki\", \"ninja\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/partes",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "partes"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Workflow 1 – POST /partes (validación falla)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));",
              "pm.test('Lista errores', () => {",
              "  const j = pm.response.json();",
              "  pm.expect(j.errors).to.be.an('array').that.is.not.empty;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"\",\n  \"type\": \"x\",\n  \"price\": -1,\n  \"categories\": []\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/partes",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "partes"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Workflow 2 – GSI: GET /partes?tipo=suspension (usa partition key)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('GSI aprovecha partition key: solo tipo=suspension', () => {",
              "  pm.expect(j.parts).to.be.an('array');",
              "  j.parts.forEach(p => {",
              "    pm.expect(p.type.toLowerCase()).to.eql('suspension');",
              "  });",
              "});",
              "pm.test('Retorna partes (GSI query eficiente)', () => {",
              "  pm.expect(j.parts.length).to.be.greaterThan(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Description",
            "value": "Usa el índice compuesto: partition key=tipo, sort key=categoria",
            "disabled": true
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/partes?tipo=suspension",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "partes"
          ],
          "query": [
            {
              "key": "tipo",
              "value": "suspension"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Workflow 2 – GSI: GET /partes?tipo=motor&categorias=kawasaki (partition + filter)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('GSI partition key (tipo=motor) + filtra categorías', () => {",
              "  j.parts.forEach(p => {",
              "    pm.expect(p.type.toLowerCase()).to.eql('motor');",
              "    pm.expect(p.categories).to.include('kawasaki');",
              "  });",
              "});",
              "pm.test('Retorna solo partes que coinciden ambos filtros', () => {",
              "  pm.expect(j.parts).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Description",
            "value": "GSI busca by tipo (partition key), luego filtra categorías en memoria",
            "disabled": true
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/partes?tipo=motor&categorias=electrico",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "partes"
          ],
          "query": [
            {
              "key": "tipo",
              "value": "motor"
            },
            {
              "key": "categorias",
              "value": "electrico"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Workflow 2 – GET /partes?tipo=frenos (búsqueda por tipo)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('Solo tipo frenos', () => {",
              "  j.parts.forEach(p => pm.expect(p.type.toLowerCase()).to.eql('frenos'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/partes?tipo=frenos",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "partes"
          ],
          "query": [
            {
              "key": "tipo",
              "value": "frenos"
            }
          ]
        }
